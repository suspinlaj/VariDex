<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:strokeColor="@color/grisecito"
    app:strokeWidth="3dp"
    app:cardElevation="8dp">

    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@color/azulitoClarito">


        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Error"
            android:layout_marginStart="10dp"
            android:fontFamily="@font/tpyletra1negrito"
            android:textSize="30sp"
            android:textColor="@color/grisecito"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMensaje"
            android:fontFamily="@font/typletra1"
            android:layout_marginStart="10dp"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/grisecito"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:text="Mensaje\nError" />

        <TextView
            android:id="@+id/btnAceptar"
            android:backgroundTint="@color/white"
            android:textColor="@color/white"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="22sp"
            android:fontFamily="@font/tpyletra1negrito"
            android:layout_gravity="end"
            android:text="volver" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>