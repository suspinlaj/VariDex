<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:clickable="true"
    android:focusable="true"
    android:background="@drawable/fondolistview"
    android:layout_marginBottom="20dp">

    <!-- Textos -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <!-- Madera -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/tvMaderaLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/tpyletra1negrito"
                    style="@style/TitulosListView"
                    android:text="Madera:" />

                <TextView
                    android:id="@+id/tvMaderaValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/ValoresListView"/>
            </LinearLayout>

            <!-- Núcleo -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/tvNucleoLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/tpyletra1negrito"
                    style="@style/TitulosListView"
                    android:text="Núcleo:" />

                <TextView
                    android:id="@+id/tvNucleoValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/ValoresListView"/>
            </LinearLayout>

        </LinearLayout>


        <!-- Personaje -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPersonajeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Personaje:"
                style="@style/TitulosListView" />

            <TextView
                android:id="@+id/tvPersonajeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/ValoresListView"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Imagen -->
    <ImageView
        android:id="@+id/imgEstadoVarita"
        android:layout_width="90dp"
        android:layout_height="match_parent"
        android:src="@drawable/varita3"/>
</LinearLayout>
